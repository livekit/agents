LIVEKIT_API_SECRET="<your livekit api secret>"
LIVEKIT_API_KEY="<your livekit api key>"
LIVEKIT_URL="<your livekit ws url>"

# Rumik AI TTS plugin
RUMIK_API_KEY="your-rumik-api-key"
# Optional: override the Rumik gateway (defaults to https://silk-api.rumik.ai)
RUMIK_GATEWAY_URL="https://silk-api.rumik.ai"
# Optional: pick the voice model -- "muga" (default) or "mulberry"
RUMIK_AI_MODEL="muga"
